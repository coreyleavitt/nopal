# nopal configuration - mwan3 replacement
#
# Migration notes for mwan3 users:
#   Renamed options (mwan3 -> nopal):
#     interval        -> probe_interval
#     timeout         -> probe_timeout
#     up              -> up_count
#     down            -> down_count
#     size            -> probe_size
#     failure_latency -> latency_threshold
#     failure_loss    -> loss_threshold
#   HTTPS probes:
#     mwan3: track_method 'httping' + httping_ssl '1'
#     nopal:  track_method 'https'
#   initial_state defaults to 'offline' (mwan3 defaults to 'online')
#   nping-* methods are not supported (nmap dependency); nopal warns and
#     suggests native alternatives (ping, dns, http, https, arping)
#   mark_mask defaults to 0xFF00 (254 interfaces); configurable via
#     option mark_mask '0xFF00' in globals section

config globals 'globals'
    option enabled '1'
    option log_level 'info'
    option conntrack_flush 'selective'
    option ipv6_enabled '1'
    option ipc_socket '/var/run/nopal.sock'

config interface 'wan'
    option enabled '1'
    option device 'eth0.2'
    option family 'both'
    option metric '10'
    option weight '50'
    option track_method 'ping'
    list   track_ip '8.8.8.8'
    list   track_ip '1.1.1.1'
    list   track_ip '2001:4860:4860::8888'
    option reliability '2'
    option probe_interval '5'
    option probe_timeout '2'
    option up_count '3'
    option down_count '5'
    option dampening '1'
    option dampening_halflife '30'
    option dampening_ceiling '2000'
    option dampening_suppress '1500'
    option dampening_reuse '500'
    option update_dns '1'
    list   dns_server '8.8.8.8'
    option clamp_mss '1'

config interface 'wanb'
    option enabled '1'
    option device 'eth0.3'
    option family 'both'
    option metric '20'
    option weight '50'
    option track_method 'ping'
    list   track_ip '8.8.4.4'
    list   track_ip '1.0.0.1'
    list   track_ip '2606:4700:4700::1111'
    option reliability '2'
    option probe_interval '5'
    option probe_timeout '2'
    option up_count '3'
    option down_count '5'
    option update_dns '1'
    list   dns_server '8.8.4.4'
    option clamp_mss '1'

config member 'wan_m1_w50'
    option interface 'wan'
    option metric '1'
    option weight '50'

config member 'wanb_m1_w50'
    option interface 'wanb'
    option metric '1'
    option weight '50'

config policy 'balanced'
    list use_member 'wan_m1_w50'
    list use_member 'wanb_m1_w50'
    option last_resort 'default'

config rule 'default_rule'
    option proto 'all'
    option family 'any'
    option sticky '1'
    option sticky_timeout '600'
    option sticky_mode 'flow'
    option use_policy 'balanced'
