# nopal - Multi-WAN policy routing manager for OpenWrt
#
# WAN interfaces are auto-discovered from the firewall wan zone.
# Per-interface overrides are optional — add a config interface
# section to customize a specific WAN (unset fields inherit from
# globals below).
#
# IMPORTANT: Set different metrics on your WAN interfaces in
# /etc/config/network so both default routes coexist in the kernel:
#
#   config interface 'wan'
#       option metric '10'
#
#   config interface 'wan2'
#       option metric '20'
#
# Without distinct metrics, only one WAN has a default route in the
# main table. nopal handles routing regardless, but the router's own
# traffic during boot or daemon downtime will only use one WAN.
#
# See: https://github.com/coreyleavitt/nopal

config globals 'globals'
    option enabled '1'
    option log_level 'info'
    option track_method 'ping'
    list track_ip '8.8.8.8'
    list track_ip '1.1.1.1'
    option probe_interval '5'
    option probe_timeout '2'
    option up_count '3'
    option down_count '5'
    option conntrack_flush 'selective'
