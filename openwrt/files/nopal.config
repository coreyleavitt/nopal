# nopal - Multi-WAN policy routing manager for OpenWrt
#
# WAN interfaces are auto-discovered from the firewall wan zone.
# Per-interface overrides are optional — add a config interface
# section to customize a specific WAN (unset fields inherit from
# globals below).
#
# IMPORTANT: Set different metrics on your WAN interfaces in
# /etc/config/network so both default routes coexist in the kernel:
#
#   config interface 'wan'
#       option metric '10'
#
#   config interface 'wan2'
#       option metric '20'
#
# Without distinct metrics, only one WAN has a default route in the
# main table. nopal handles routing regardless, but the router's own
# traffic during boot or daemon downtime will only use one WAN.
#
# See: https://github.com/coreyleavitt/nopal

config globals 'globals'
    option enabled '1'
    option log_level 'info'         # debug, info, notice, warn, error
    option track_method 'ping'      # ping, dns, http, arping
    list track_ip '8.8.8.8'
    list track_ip '1.1.1.1'
    option probe_interval '5'       # seconds between probes (online)
    option probe_timeout '2'        # seconds before probe timeout
    option up_count '3'             # successes to go online
    option down_count '5'           # failures to go offline
    option conntrack_flush 'selective'  # selective, full, none
    # option mark_mask '0xFF00'     # fwmark bit mask (default: 0xFF00)
    # option logging '0'            # per-rule nftables logging

# Per-interface overrides (optional — inherits from globals if unset):
#
# config interface 'wan'
#     option track_method 'dns'          # override probe type
#     option probe_interval '10'         # slower probing when online
#     option failure_interval '2'        # faster probing when offline
#     option recovery_interval '3'       # probing when degraded
#     # option keep_failure_interval '0' # use failure_interval during probing too
#     # option check_quality '1'         # enable latency/loss monitoring
#     # option failure_latency '500'     # ms threshold for degraded
#     # option recovery_latency '200'    # ms threshold for recovery
#     # option failure_loss '40'         # % loss threshold for degraded
#     # option recovery_loss '10'        # % loss threshold for recovery
